# Copy to .env on the server (docker compose reads it automatically).
#
# FRED API key — powers the macro component (M2 YoY, Fed Funds, yield curve,
# real rates). Without it the macro component is held at a neutral 0.5 fallback
# and the UI shows "macro n/a" (the model still works, just without macro).
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- Authentication -----------------------------------------------------------
# Session signing secret, >= 32 chars. Generate: openssl rand -hex 32
# Rotating it logs EVERY user out (that is also the break-glass lever).
AUTH_SECRET=

# Initial admin account, seeded once into an EMPTY user store on first request.
# After seeding these are ignored; change the password at /account.
# If the auth volume is ever wiped, the admin re-seeds from these values
# (= lockout recovery path).
ADMIN_USERNAME=Niilo
ADMIN_PASSWORD=
